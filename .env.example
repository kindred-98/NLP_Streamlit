# Proveedor: ollama, openai, huggingface
NLP_PROVIDER=ollama

# Modelo a usar
NLP_MODEL=qwen2.5:0.5b

# Ollama (local)
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# OpenAI (cloud) - opcional
# OPENAI_API_KEY=sk-...

# HuggingFace (cloud) - opcional
# HF_TOKEN=hf_...
# HF_ENDPOINT=https://api-inference.huggingface.co/models/meta-llama/Llama-2-7b-chat-hf